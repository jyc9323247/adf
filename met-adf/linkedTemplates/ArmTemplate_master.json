{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory 이름",
			"defaultValue": "met-adf"
		},
		"default_properties_testparm_value": {
			"type": "string",
			"defaultValue": "778884"
		},
		"default_properties_netwt2324_value": {
			"type": "string",
			"defaultValue": "adfdsdfdfs"
		},
		"default_properties_ttere_value": {
			"type": "string",
			"defaultValue": "dfafddsf"
		},
		"default_properties_dfadfsf122123d_value": {
			"type": "string",
			"defaultValue": "afdfafdfds"
		},
		"containerUri": {
			"type": "string",
			"metadata": "스토리지 계정 연결 된 ARM 서식 파일을 포함 하는 URI입니다."
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "연결된 ARM 템플릿을 포함하는 스토리지 계정에 대한 SAS 토큰"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "met-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"default_properties_testparm_value": {
						"value": "[parameters('default_properties_testparm_value')]"
					},
					"default_properties_netwt2324_value": {
						"value": "[parameters('default_properties_netwt2324_value')]"
					},
					"default_properties_ttere_value": {
						"value": "[parameters('default_properties_ttere_value')]"
					},
					"default_properties_dfadfsf122123d_value": {
						"value": "[parameters('default_properties_dfadfsf122123d_value')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}